# ═══════════════════════════════════════════════════════════════════════
# AdPilot Environment Configuration
# Copy to .env and fill in values. Variables marked [REQUIRED] must be set.
# ═══════════════════════════════════════════════════════════════════════

# App [REQUIRED]
NEXT_PUBLIC_APP_URL=https://adpilot.yourdomain.com
NODE_ENV=production

# Database [REQUIRED]
DATABASE_URL=postgresql://adpilot:PASSWORD@localhost:5432/adpilot
DB_PASSWORD=

# Redis [REQUIRED]
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Auth [REQUIRED]
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://adpilot.yourdomain.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft / Azure AD OAuth [OPTIONAL]
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Encryption (for platform tokens) [REQUIRED]
MASTER_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# Facebook/Meta [OPTIONAL]
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_WEBHOOK_VERIFY_TOKEN=

# TikTok [OPTIONAL]
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# LinkedIn [OPTIONAL]
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Twitter/X [OPTIONAL]
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Google (YouTube + Ads) [OPTIONAL]
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# Pinterest [OPTIONAL]
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Snapchat [OPTIONAL]
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# Cloudflare R2 [OPTIONAL]
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=adpilot-media
R2_PUBLIC_URL=

# Resend (Email) [OPTIONAL]
RESEND_API_KEY=
EMAIL_FROM=AdPilot <noreply@adpilot.com>

# Axiom (Logging) [OPTIONAL]
AXIOM_DATASET=adpilot
AXIOM_TOKEN=

# Stripe (Billing) [OPTIONAL]
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_AGENCY_PRICE_ID=price_xxx

# PostHog (Feature Flags) [OPTIONAL]
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Umami (Analytics) [OPTIONAL]
NEXT_PUBLIC_UMAMI_URL=https://analytics.yourdomain.com
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Claude API (AI features — Agency plan only) [OPTIONAL]
ANTHROPIC_API_KEY=

# Admin [OPTIONAL — for seeding initial admin account]
ADMIN_SEED_PASSWORD=
ADMIN_SESSION_SECRET=

# Stripe Price IDs [REQUIRED for billing]
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx
STRIPE_PRICE_AGENCY_MONTHLY=price_xxx
STRIPE_PRICE_AGENCY_ANNUAL=price_xxx

# Cloudflare Tunnel [OPTIONAL — set to enable tunnel profile]
CF_TUNNEL_TOKEN=
