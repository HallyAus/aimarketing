generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  AGENCY
}

enum Role {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum Platform {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  LINKEDIN
  TWITTER_X
  GOOGLE_ADS
  YOUTUBE
  PINTEREST
  SNAPCHAT
}

enum ConnectionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
  DEACTIVATED
}

enum SystemRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  PAUSED
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
}

enum VerificationType {
  EMAIL_VERIFICATION
  PASSWORD_SETUP
  TEAM_INVITE
  PASSWORD_RESET
  EMAIL_CHANGE
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum UsageMetric {
  POSTS_PUBLISHED
  AI_TOKENS_USED
  API_CALLS
  MEDIA_STORAGE_MB
  TEAM_MEMBERS
  CONNECTED_ACCOUNTS
}

enum AnnouncementType {
  INFO
  WARNING
  MAINTENANCE
  FEATURE
}

enum CampaignObjective {
  AWARENESS
  TRAFFIC
  ENGAGEMENT
  CONVERSIONS
  LEADS
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
  FAILED
}

enum PostStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  DELETED
}

enum CreativeType {
  IMAGE
  VIDEO
  CAROUSEL
  STORY
  REEL
}

// ── Models ───────────────────────────────────────────────────────────────

model Organization {
  id                   String             @id @default(cuid())
  name                 String
  slug                 String             @unique
  plan                 Plan               @default(FREE)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  billingEmail         String?
  billingCycleAnchor   DateTime?
  defaultTimezone      String             @default("UTC")
  industry             String?
  companySize          String? // "1-10", "11-50", "51-200", "201-500", "500+"
  website              String?
  country              String?
  subscriptionStatus   SubscriptionStatus @default(ACTIVE)
  billingCycle         BillingCycle       @default(MONTHLY)
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  maxUsers             Int                @default(1)
  maxPlatforms         Int                @default(3)
  maxPostsPerMonth     Int                @default(30)
  postsUsedThisMonth   Int                @default(0)
  postsResetAt         DateTime?
  features             Json? // org-level feature flag overrides
  publishingPaused     Boolean            @default(false)
  metadata             Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime?

  memberships         Membership[]
  invitations         Invitation[]
  platformConnections PlatformConnection[]
  pages               Page[]
  campaigns           Campaign[]
  posts               Post[]
  creatives           Creative[]
  auditLogs           AuditLog[]
  postTemplates       PostTemplate[]
  contentTemplates    ContentTemplate[]
  webhookRules        WebhookRule[]
  leadCaptures        LeadCapture[]
  utmLinks            UtmLink[]
  performanceReports  PerformanceReport[]
  invoices            Invoice[]
  usageRecords        UsageRecord[]
  communityTopics     CommunityTopic[]

  @@index([deletedAt])
  @@index([plan])
  @@index([subscriptionStatus])
  @@index([createdAt])
  @@index([plan, subscriptionStatus, deletedAt])
  @@index([plan, subscriptionStatus, billingCycle, deletedAt])
}

model User {
  id                   String     @id @default(cuid())
  email                String     @unique
  name                 String?
  avatar               String?
  emailVerified        DateTime?
  password             String? // bcrypt hashed, null for OAuth/magic-link users
  passwordResetToken   String?    @unique
  passwordResetExpires DateTime?
  timezone             String     @default("UTC") // IANA timezone, auto-detected
  locale               String     @default("en-US")
  dateFormat           String     @default("auto") // auto | 12h | 24h
  lastLoginAt          DateTime?
  lastLoginIp          String?
  loginCount           Int        @default(0)
  status               UserStatus @default(ACTIVE)
  systemRole           SystemRole @default(USER)
  onboardingComplete   Boolean    @default(false)
  lastSelectedPageId   String?
  setupComplete        Boolean    @default(false)
  invitedBy            String?
  deletedAt            DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  memberships        Membership[]
  emailVerifications EmailVerification[]
  invitationsSent    Invitation[]         @relation("InvitedBy")
  connectionsAdded   PlatformConnection[] @relation("ConnectedBy")
  campaignsCreated   Campaign[]           @relation("CreatedBy")
  postsApproved      Post[]               @relation("ApprovedBy")
  auditLogs          AuditLog[]
  templatesCreated   PostTemplate[]       @relation("TemplateCreatedBy")
  authenticators     Authenticator[]
  twoFactorSecret    TwoFactorSecret?
  approvalRequests   ApprovalRequest[]    @relation("ApprovalRequester")
  approvalReviews    ApprovalRequest[]    @relation("ApprovalReviewer")
  apiKeys            ApiKey[]

  // NextAuth fields
  accounts Account[]
  sessions Session[]

  @@index([status])
  @@index([systemRole])
  @@index([createdAt])
  @@index([deletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Membership {
  id         String    @id @default(cuid())
  userId     String
  orgId      String
  role       Role
  invitedBy  String?
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
  @@index([userId])
}

model Invitation {
  id         String       @id @default(cuid())
  orgId      String
  email      String
  role       Role
  token      String       @unique
  expiresAt  DateTime
  invitedBy  String
  status     InviteStatus @default(PENDING)
  message    String?
  acceptedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  inviter      User         @relation("InvitedBy", fields: [invitedBy], references: [id])

  @@index([orgId])
  @@index([email])
  @@index([invitedBy])
  @@index([token])
  @@index([status])
}

model PlatformConnection {
  id                  String           @id @default(cuid())
  orgId               String
  platform            Platform
  accessToken         String // Encrypted at application level
  refreshToken        String? // Encrypted at application level
  tokenExpiresAt      DateTime?
  platformUserId      String
  platformAccountName String?
  scopes              String[]
  status              ConnectionStatus @default(ACTIVE)
  connectedBy         String
  metadata            Json?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  connector    User         @relation("ConnectedBy", fields: [connectedBy], references: [id])
  pages        Page[]

  @@unique([orgId, platform, platformUserId])
  @@index([orgId])
  @@index([platform, status])
  @@index([connectedBy])
}

model Campaign {
  id              String            @id @default(cuid())
  orgId           String
  pageId          String?
  name            String
  objective       CampaignObjective
  status          CampaignStatus    @default(DRAFT)
  budget          Decimal?          @db.Decimal(12, 2)
  currency        String            @default("USD")
  startDate       DateTime?
  endDate         DateTime?
  targetPlatforms Platform[]
  audienceConfig  Json?
  createdBy       String
  version         Int               @default(1)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  page         Page?        @relation(fields: [pageId], references: [id])
  creator      User         @relation("CreatedBy", fields: [createdBy], references: [id])
  posts        Post[]

  @@index([orgId])
  @@index([pageId])
  @@index([status])
  @@index([createdBy])
}

model Post {
  id                 String     @id @default(cuid())
  campaignId         String?
  orgId              String
  pageId             String?
  platform           Platform
  content            String
  mediaUrls          String[]
  scheduledAt        DateTime?
  publishedAt        DateTime?
  platformPostId     String?
  status             PostStatus @default(DRAFT)
  approvedBy         String?
  rejectionReason    String?
  engagementSnapshot Json?
  errorMessage       String?
  pageName           String?
  sourceUrl          String?
  tone               String?
  version            Int        @default(1)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  campaign        Campaign?           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  organization    Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  page            Page?               @relation(fields: [pageId], references: [id])
  approver        User?               @relation("ApprovedBy", fields: [approvedBy], references: [id])
  analytics       AnalyticsSnapshot[]
  approvalRequest ApprovalRequest?
  utmLinks        UtmLink[]

  @@index([orgId])
  @@index([pageId])
  @@index([status, scheduledAt])
  @@index([campaignId])
  @@index([approvedBy])
  @@index([orgId, status])
  @@index([orgId, pageId, status])
  @@index([orgId, status, publishedAt])
}

model Creative {
  id            String       @id @default(cuid())
  orgId         String
  name          String
  type          CreativeType
  r2Key         String
  r2Url         String
  thumbnailUrl  String?
  dimensions    String?
  fileSizeBytes BigInt
  mimeType      String
  tags          String[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model AnalyticsSnapshot {
  id          String   @id @default(cuid())
  postId      String
  platform    Platform
  snapshotAt  DateTime
  impressions Int      @default(0)
  reach       Int      @default(0)
  clicks      Int      @default(0)
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  saves       Int      @default(0)
  videoViews  Int      @default(0)
  spend       Decimal  @default(0) @db.Decimal(12, 2)
  conversions Int      @default(0)
  ctr         Float    @default(0)
  cpc         Decimal  @default(0) @db.Decimal(12, 4)
  cpm         Decimal  @default(0) @db.Decimal(12, 4)
  rawPayload  Json?
  createdAt   DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([snapshotAt])
  @@index([platform])
  @@index([postId, snapshotAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  orgId      String?
  userId     String?
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([entityType, entityId])
  @@index([userId])
}

model WebhookEvent {
  id              String    @id @default(cuid())
  platform        Platform
  eventType       String
  platformEventId String?
  payload         Json
  signature       String?
  verified        Boolean   @default(false)
  processedAt     DateTime?
  processingError String?
  createdAt       DateTime  @default(now())

  @@unique([platform, platformEventId])
  @@index([platform, createdAt])
  @@index([processedAt])
}

model PostTemplate {
  id        String    @id @default(cuid())
  orgId     String
  name      String
  platform  Platform?
  content   String
  mediaUrls String[]
  tags      String[]
  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator      User         @relation("TemplateCreatedBy", fields: [createdBy], references: [id])

  @@index([orgId])
  @@index([createdBy])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
  @@index([userId])
}

model TwoFactorSecret {
  id          String    @id @default(cuid())
  userId      String    @unique
  secret      String    // base32-encoded TOTP secret
  backupCodes String[]  // hashed backup codes
  verified    Boolean   @default(false)
  enabledAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Page / Account Segregation ──────────────────────────────────────────

model Page {
  id             String   @id @default(cuid())
  orgId          String
  connectionId   String
  platform       Platform
  platformPageId String // e.g., Facebook page ID
  name           String // e.g., "Printforge"
  pictureUrl     String?
  avatarUrl      String?
  accessToken    String // encrypted page-specific access token
  isActive       Boolean  @default(true)
  followerCount  Int?     @default(0)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization       Organization               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  connection         PlatformConnection         @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  posts              Post[]
  campaigns          Campaign[]
  brandVoices        BrandVoice[]
  hashtagSets        HashtagSet[]
  contentTemplates   ContentTemplate[]
  rssFeeds           RssFeed[]
  webhookRules       WebhookRule[]
  leadCaptures       LeadCapture[]
  performanceReports PerformanceReport[]
  ingestionJobs      IngestionJob[]
  historicalPosts    HistoricalPost[]
  historicalMetrics  HistoricalMetricSnapshot[]
  cachedInsights     CachedInsight[]

  @@unique([orgId, platform, platformPageId])
  @@index([orgId])
  @@index([connectionId])
  @@index([orgId, isActive])
}

// ── Future-proof Models ─────────────────────────────────────────────────

model BrandVoice {
  id          String   @id @default(cuid())
  pageId      String
  name        String // e.g., "Professional", "Casual"
  description String?
  sampleTexts String[] // array of sample content
  aiPrompt    String? // generated system prompt for this voice
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}

model HashtagSet {
  id        String   @id @default(cuid())
  pageId    String
  name      String
  hashtags  String[]
  category  String?
  createdAt DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}

model ContentTemplate {
  id          String    @id @default(cuid())
  pageId      String? // null = org-wide
  orgId       String
  name        String
  platform    Platform?
  contentBody String
  mediaUrls   String[]
  category    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  page         Page?        @relation(fields: [pageId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([pageId])
}

model ApprovalRequest {
  id          String    @id @default(cuid())
  postId      String    @unique
  requestedBy String
  reviewedBy  String?
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  comment     String?
  createdAt   DateTime  @default(now())
  reviewedAt  DateTime?

  post      Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  requester User  @relation("ApprovalRequester", fields: [requestedBy], references: [id])
  reviewer  User? @relation("ApprovalReviewer", fields: [reviewedBy], references: [id])

  @@index([requestedBy])
  @@index([reviewedBy])
  @@index([status])
}

model RssFeed {
  id            String    @id @default(cuid())
  pageId        String
  url           String
  name          String?
  isActive      Boolean   @default(true)
  checkInterval Int       @default(3600) // seconds
  lastCheckedAt DateTime?
  lastItemGuid  String?
  autoPost      Boolean   @default(false)
  tone          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([isActive])
}

model WebhookRule {
  id        String   @id @default(cuid())
  orgId     String
  pageId    String?
  name      String
  trigger   String // e.g., "POST_LIKES_100", "POST_PUBLISHED", "CONNECTION_EXPIRED"
  action    String // e.g., "CREATE_POST", "SEND_EMAIL", "WEBHOOK_URL"
  config    Json // action-specific configuration
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  page         Page?        @relation(fields: [pageId], references: [id])

  @@index([orgId])
  @@index([pageId])
}

model LeadCapture {
  id        String   @id @default(cuid())
  orgId     String
  pageId    String?
  name      String
  email     String
  company   String?
  source    String? // which form/page captured this
  metadata  Json?
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  page         Page?        @relation(fields: [pageId], references: [id])

  @@index([orgId])
  @@index([pageId])
}

model UtmLink {
  id        String   @id @default(cuid())
  orgId     String
  postId    String?
  url       String
  source    String
  medium    String
  campaign  String
  term      String?
  content   String?
  shortUrl  String?  @unique
  clicks    Int      @default(0)
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  post         Post?        @relation(fields: [postId], references: [id])

  @@index([orgId])
  @@index([postId])
}

model PerformanceReport {
  id         String   @id @default(cuid())
  orgId      String
  pageId     String?
  reportType String // WEEKLY, MONTHLY, CUSTOM
  startDate  DateTime
  endDate    DateTime
  data       Json // aggregated metrics
  pdfUrl     String? // stored PDF
  sentTo     String[] // email addresses
  createdAt  DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  page         Page?        @relation(fields: [pageId], references: [id])

  @@index([orgId])
  @@index([pageId])
}

// ── Admin & Billing Models ──────────────────────────────────────────────

model Invoice {
  id                  String        @id @default(cuid())
  orgId               String
  stripeInvoiceId     String        @unique
  stripePaymentIntent String?
  number              String?
  status              InvoiceStatus
  amountDue           Int // cents
  amountPaid          Int // cents
  currency            String        @default("usd")
  hostedInvoiceUrl    String?
  invoicePdf          String?
  periodStart         DateTime
  periodEnd           DateTime
  dueDate             DateTime?
  paidAt              DateTime?
  createdAt           DateTime      @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([status])
  @@index([createdAt])
  @@index([orgId, status])
}

model UsageRecord {
  id          String      @id @default(cuid())
  orgId       String
  metric      UsageMetric
  value       Int
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime    @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, metric, periodStart])
  @@index([periodStart])
}

model PaymentMethod {
  id                    String   @id @default(cuid())
  orgId                 String
  stripePaymentMethodId String   @unique
  type                  String // "card", "bank_account", etc.
  brand                 String? // "visa", "mastercard", etc.
  last4                 String?
  expMonth              Int?
  expYear               Int?
  isDefault             Boolean  @default(false)
  createdAt             DateTime @default(now())

  @@index([orgId])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  orgId      String
  keyHash    String    @unique // bcrypt hash — never store raw key
  label      String    @default("default")
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isRevoked  Boolean   @default(false)
  scopes     String[] // ["posts:read", "posts:write", "analytics:read"]
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([orgId])
  @@index([userId])
}

model FeatureFlag {
  id              String   @id @default(cuid())
  key             String   @unique // "ai_content_studio", "webhook_automation"
  name            String
  description     String?
  enabled         Boolean  @default(false) // global default
  enabledForTiers Plan[] // enabled for these tiers
  enabledForOrgs  String[] // org IDs with override access
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([key])
}

model SystemMetric {
  id         String   @id @default(cuid())
  metric     String // "active_users", "posts_today", "api_latency_p99"
  value      Float
  tags       Json? // { "platform": "facebook", "region": "us" }
  recordedAt DateTime @default(now())

  @@index([metric, recordedAt])
}

model Announcement {
  id          String           @id @default(cuid())
  title       String
  body        String
  type        AnnouncementType @default(INFO)
  isActive    Boolean          @default(true)
  showFrom    DateTime?
  showUntil   DateTime?
  targetTiers Plan[] // empty = all tiers
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model WaitlistEntry {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  company           String?
  planInterest      Plan?
  timezone          String?
  source            String? // "homepage", "blog", "referral"
  referralCode      String?
  convertedAt       DateTime?
  convertedToUserId String?
  createdAt         DateTime  @default(now())

  @@index([email])
  @@index([createdAt])
}

// ── Historical Data Ingestion ───────────────────────────────────────────

enum IngestionStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

model IngestionJob {
  id             String          @id @default(cuid())
  pageId         String
  orgId          String
  status         IngestionStatus @default(PENDING)
  dataTypes      String[]
  totalItems     Int?
  processedItems Int             @default(0)
  failedItems    Int             @default(0)
  progress       Float           @default(0)
  platformCursor String?
  oldestPostDate DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  lastActivityAt DateTime?
  errorMessage   String?
  rateLimitHits  Int             @default(0)
  nextRetryAfter DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([status])
  @@index([orgId])
}

model HistoricalPost {
  id              String   @id @default(cuid())
  pageId          String
  orgId           String
  platformPostId  String
  platformUrl     String?
  content         String?
  mediaUrls       String[]
  postType        String?
  publishedAt     DateTime
  impressions     Int      @default(0)
  reach           Int      @default(0)
  engagements     Int      @default(0)
  likes           Int      @default(0)
  comments        Int      @default(0)
  shares          Int      @default(0)
  saves           Int      @default(0)
  clicks          Int      @default(0)
  videoViews      Int      @default(0)
  isIngested      Boolean  @default(true)
  ingestedAt      DateTime @default(now())
  rawPlatformData Json?
  createdAt       DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, platformPostId])
  @@index([pageId, publishedAt])
  @@index([orgId])
}

model HistoricalMetricSnapshot {
  id              String   @id @default(cuid())
  pageId          String
  orgId           String
  metricDate      DateTime
  followers       Int?
  followersChange Int?
  pageViews       Int?
  pageImpressions Int?
  pageReach       Int?
  pageEngagement  Int?
  audienceData    Json?
  rawPlatformData Json?
  createdAt       DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, metricDate])
  @@index([pageId, metricDate])
  @@index([orgId])
}

// ── Email Verification Tokens ───────────────────────────────────────

model EmailVerification {
  id        String           @id @default(cuid())
  userId    String
  email     String
  token     String           @unique
  type      VerificationType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([email])
}

// ── AI Insights Cache ──────────────────────────────────────────────────

model CachedInsight {
  id          String   @id @default(cuid())
  pageId      String
  orgId       String
  type        String // "sentiment" | "audience" | "best-times" | "benchmarking" | "trending"
  data        Json
  generatedAt DateTime
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, type])
  @@index([pageId, type])
  @@index([expiresAt])
}

// ── Community Feed ────────────────────────────────────────────────────

model CommunityTopic {
  id        String   @id @default(cuid())
  orgId     String
  topic     String
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, topic])
  @@index([orgId])
}
